# Required: URL of the knowledge-harvester-pipeline API server
PIPELINE_URL=http://localhost:3001

# Required: unique user identifier for this desktop agent
USER_ID=user-1

# Required: user email, used for pipeline authentication and engram attribution
USER_EMAIL=user@company.com

# Optional: how often (ms) to poll the active window title (default: 1000)
WINDOW_POLL_INTERVAL_MS=1000

# Optional: milliseconds of inactivity before the user is considered idle (default: 300000 = 5 min)
IDLE_THRESHOLD_MS=300000

# Optional: interval (ms) between periodic desktop captures sent to the pipeline (default: 60000 = 1 min)
PERIODIC_CAPTURE_MS=60000

# Optional: port for the local dashboard UI (default: 3333)
DASHBOARD_PORT=3333

# Optional: logging verbosity — error | warn | info | debug (default: info)
LOG_LEVEL=info
